@{
    ViewData["Title"] = "Home";
}
<h1>Asset Manager</h1>
<p>Laptop table aligned to your latest header format.</p>

<section class="card">
    <h2 id="form-title">Create Asset</h2>
    <form id="asset-form">
        <input type="hidden" id="asset-id" />
        <div class="grid">
            <label>Asset type<input id="assetType" value="Laptop" /></label>
            <label>Asset Manufacturer<input id="assetManufacturer" /></label>
            <label>Service Tag<input id="serviceTag" required /></label>
            <label>Model<input id="model" /></label>
            <label>P/N<input id="pn" /></label>
            <label>Asset Owner<input id="assetOwner" /></label>
            <label>Assigned To<input id="assignedTo" /></label>
            <label>Asset Status<input id="assetStatus" /></label>
            <label>Last Owner<input id="lastOwner" /></label>
            <label>Dept<input id="dept" /></label>
            <label>Location<input id="location" /></label>
            <label>Asset Health<input id="assetHealth" /></label>
            <label>Warranty<input id="warranty" /></label>
            <label>Install date<input id="installDate" type="date" /></label>
            <label>Date Added/Updated<input id="dateAddedUpdated" readonly /></label>
            <label>Processor<input id="processor" /></label>
            <label>RAM<input id="ram" /></label>
            <label>HardDisk<input id="hardDisk" /></label>
            <label>O/S<input id="os" /></label>
            <label>Supt Vendor<input id="suptVendor" /></label>
            <label>Keyboard<input id="keyboard" /></label>
            <label>Mouse<input id="mouse" /></label>
            <label>HeadPhone<input id="headPhone" /></label>
            <label>USB Extender<input id="usbExtender" /></label>
            <label>Contains PII (Yes/No)
                <select id="containsPII">
                    <option value="">--</option>
                    <option value="Yes">Yes</option>
                    <option value="No">No</option>
                </select>
            </label>
            <label class="inline">Free (?) <input id="isAvailable" type="checkbox" checked /></label>
        </div>
        <div class="actions">
            <button type="submit">Save</button>
            <button type="button" id="cancel-edit" class="secondary">Cancel Edit</button>
            <button type="button" id="delete-selected" class="danger">Delete Selected</button>
            <a class="link-btn" href="/api/reports/export/laptops.xlsx" target="_blank">Export Excel</a>
        </div>
    </form>
</section>

<section class="card">
    <div class="toolbar">
        <h2>Assets</h2>
        <label class="inline"><input id="show-free-only" type="checkbox" /> Show only free assets</label>
        <button type="button" id="reload-btn">Reload</button>
    </div>
    <div class="table-wrap">
        <table id="assets-table">
            <thead>
                <tr>
                    <th>Asset type</th><th>Asset Manufacturer</th><th>Service Tag</th><th>Model</th><th>P/N</th>
                    <th>Asset Owner</th><th>Assigned To</th><th>Asset Status</th><th>Last Owner</th><th>Dept</th>
                    <th>Location</th><th>Asset Health</th><th>Warranty</th><th>Install date</th><th>Date Added/Updated</th>
                    <th>Processor</th><th>RAM</th><th>HardDisk</th><th>O/S</th><th>Supt Vendor</th>
                    <th>Keyboard</th><th>Mouse</th><th>HeadPhone</th><th>USB Extender</th><th>Contains PII (Yes/No)</th>
                    <th>Free?</th><th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
    <p id="status"></p>
</section>

<script>
(() => {
    const statusEl = document.getElementById("status");
    const tbody = document.querySelector("#assets-table tbody");
    const formTitle = document.getElementById("form-title");
    const showFreeOnly = document.getElementById("show-free-only");

    const controls = {
        id: document.getElementById("asset-id"),
        assetType: document.getElementById("assetType"),
        assetManufacturer: document.getElementById("assetManufacturer"),
        serviceTag: document.getElementById("serviceTag"),
        model: document.getElementById("model"),
        pn: document.getElementById("pn"),
        assetOwner: document.getElementById("assetOwner"),
        assignedTo: document.getElementById("assignedTo"),
        assetStatus: document.getElementById("assetStatus"),
        lastOwner: document.getElementById("lastOwner"),
        dept: document.getElementById("dept"),
        location: document.getElementById("location"),
        assetHealth: document.getElementById("assetHealth"),
        warranty: document.getElementById("warranty"),
        installDate: document.getElementById("installDate"),
        dateAddedUpdated: document.getElementById("dateAddedUpdated"),
        processor: document.getElementById("processor"),
        ram: document.getElementById("ram"),
        hardDisk: document.getElementById("hardDisk"),
        os: document.getElementById("os"),
        suptVendor: document.getElementById("suptVendor"),
        keyboard: document.getElementById("keyboard"),
        mouse: document.getElementById("mouse"),
        headPhone: document.getElementById("headPhone"),
        usbExtender: document.getElementById("usbExtender"),
        containsPII: document.getElementById("containsPII"),
        isAvailable: document.getElementById("isAvailable")
    };

    const text = (v) => (v ?? "").toString().trim();
    const d = (v) => v ? new Date(v).toLocaleDateString() : "";
    const dt = (v) => v ? new Date(v).toLocaleString() : "";
    const cell = (v) => v == null ? "" : String(v);
    const statusFrom = (row) => row.isAvailable ? "Free" : (row.assetHealth || "In Use");

    function setStatus(msg, err = false) {
        statusEl.textContent = msg;
        statusEl.className = err ? "error" : "ok";
    }

    function clearForm() {
        Object.values(controls).forEach(el => { if ("value" in el) el.value = ""; });
        controls.assetType.value = "Laptop";
        controls.isAvailable.checked = true;
        formTitle.textContent = "Create Asset";
    }

    function toPayload() {
        return {
            id: controls.id.value ? Number(controls.id.value) : 0,
            assetType: text(controls.assetType.value),
            assetManufacturer: text(controls.assetManufacturer.value),
            serviceTag: text(controls.serviceTag.value),
            model: text(controls.model.value),
            pn: text(controls.pn.value),
            assetOwner: text(controls.assetOwner.value),
            // Assigned To not in DB schema yet; keeping it as UI-only for now.
            lastOwner: text(controls.lastOwner.value),
            dept: text(controls.dept.value),
            location: text(controls.location.value),
            assetHealth: text(controls.assetHealth.value),
            warranty: text(controls.warranty.value),
            installDate: controls.installDate.value ? new Date(controls.installDate.value).toISOString() : null,
            processor: text(controls.processor.value),
            ram: text(controls.ram.value),
            hardDisk: text(controls.hardDisk.value),
            os: text(controls.os.value),
            suptVendor: text(controls.suptVendor.value),
            keyboard: text(controls.keyboard.value),
            mouse: text(controls.mouse.value),
            headPhone: text(controls.headPhone.value),
            usbExtender: text(controls.usbExtender.value),
            containsPII: text(controls.containsPII.value),
            isAvailable: controls.isAvailable.checked
        };
    }

    async function fetchAssets() {
        const url = showFreeOnly.checked ? "/api/laptops/free" : "/api/laptops";
        const res = await fetch(url);
        if (!res.ok) throw new Error("Failed to load assets");
        return await res.json();
    }

    function renderRows(rows) {
        tbody.innerHTML = "";
        if (!rows.length) {
            tbody.innerHTML = "<tr><td colspan='27'>No assets found.</td></tr>";
            return;
        }
        rows.forEach(row => {
            const tr = document.createElement("tr");
            tr.dataset.row = JSON.stringify(row);
            tr.innerHTML = `
                <td>${cell(row.assetType)}</td><td>${cell(row.assetManufacturer)}</td><td>${cell(row.serviceTag)}</td><td>${cell(row.model)}</td><td>${cell(row.pn)}</td>
                <td>${cell(row.assetOwner)}</td><td>${cell(row.assetOwner)}</td><td>${cell(statusFrom(row))}</td><td>${cell(row.lastOwner)}</td><td>${cell(row.dept)}</td>
                <td>${cell(row.location)}</td><td>${cell(row.assetHealth)}</td><td>${cell(row.warranty)}</td><td>${d(row.installDate)}</td><td>${dt(row.dateAddedUpdated)}</td>
                <td>${cell(row.processor)}</td><td>${cell(row.ram)}</td><td>${cell(row.hardDisk)}</td><td>${cell(row.os)}</td><td>${cell(row.suptVendor)}</td>
                <td>${cell(row.keyboard)}</td><td>${cell(row.mouse)}</td><td>${cell(row.headPhone)}</td><td>${cell(row.usbExtender)}</td><td>${cell(row.containsPII)}</td>
                <td>${row.isAvailable ? "Yes" : "No"}</td>
                <td><button data-action="edit">Edit</button> <button data-action="delete" class="danger">Delete</button></td>
            `;
            tbody.appendChild(tr);
        });
    }

    async function reload() {
        try {
            setStatus("Loading...");
            const rows = await fetchAssets();
            renderRows(rows);
            setStatus(`Loaded ${rows.length} assets.`);
        } catch (e) {
            setStatus(e.message || "Load failed", true);
        }
    }

    document.getElementById("asset-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!text(controls.serviceTag.value)) return setStatus("Service Tag is required.", true);
        const isEdit = !!controls.id.value;
        const url = isEdit ? `/api/laptops/${controls.id.value}` : "/api/laptops";
        const method = isEdit ? "PUT" : "POST";
        const res = await fetch(url, { method, headers: { "Content-Type": "application/json" }, body: JSON.stringify(toPayload()) });
        if (!res.ok) return setStatus("Save failed.", true);
        clearForm();
        await reload();
        setStatus(isEdit ? "Asset updated." : "Asset created.");
    });

    document.getElementById("cancel-edit").addEventListener("click", () => { clearForm(); setStatus("Edit cancelled."); });
    document.getElementById("reload-btn").addEventListener("click", reload);
    showFreeOnly.addEventListener("change", reload);

    document.getElementById("delete-selected").addEventListener("click", async () => {
        const id = controls.id.value;
        if (!id) return setStatus("Select a row first to delete.", true);
        if (!confirm(`Delete asset #${id}?`)) return;
        const res = await fetch(`/api/laptops/${id}`, { method: "DELETE" });
        if (!res.ok) return setStatus("Delete failed.", true);
        clearForm();
        await reload();
        setStatus("Asset deleted.");
    });

    tbody.addEventListener("click", async (e) => {
        const tr = e.target.closest("tr");
        if (!tr || !tr.dataset.row) return;
        const row = JSON.parse(tr.dataset.row);
        const action = e.target.getAttribute("data-action");
        if (action === "delete") {
            if (!confirm(`Delete asset ${row.serviceTag || row.id}?`)) return;
            const res = await fetch(`/api/laptops/${row.id}`, { method: "DELETE" });
            if (!res.ok) return setStatus("Delete failed.", true);
            await reload();
            setStatus("Asset deleted.");
            return;
        }
        controls.id.value = row.id ?? "";
        controls.assetType.value = row.assetType ?? "";
        controls.assetManufacturer.value = row.assetManufacturer ?? "";
        controls.serviceTag.value = row.serviceTag ?? "";
        controls.model.value = row.model ?? "";
        controls.pn.value = row.pn ?? "";
        controls.assetOwner.value = row.assetOwner ?? "";
        controls.assignedTo.value = row.assetOwner ?? "";
        controls.assetStatus.value = statusFrom(row);
        controls.lastOwner.value = row.lastOwner ?? "";
        controls.dept.value = row.dept ?? "";
        controls.location.value = row.location ?? "";
        controls.assetHealth.value = row.assetHealth ?? "";
        controls.warranty.value = row.warranty ?? "";
        controls.installDate.value = row.installDate ? String(row.installDate).slice(0, 10) : "";
        controls.dateAddedUpdated.value = dt(row.dateAddedUpdated);
        controls.processor.value = row.processor ?? "";
        controls.ram.value = row.ram ?? "";
        controls.hardDisk.value = row.hardDisk ?? "";
        controls.os.value = row.os ?? "";
        controls.suptVendor.value = row.suptVendor ?? "";
        controls.keyboard.value = row.keyboard ?? "";
        controls.mouse.value = row.mouse ?? "";
        controls.headPhone.value = row.headPhone ?? "";
        controls.usbExtender.value = row.usbExtender ?? "";
        controls.containsPII.value = row.containsPII ?? "";
        controls.isAvailable.checked = !!row.isAvailable;
        formTitle.textContent = `Edit Asset #${row.id}`;
        window.scrollTo({ top: 0, behavior: "smooth" });
    });

    clearForm();
    reload();
})();
</script>
